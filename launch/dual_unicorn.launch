<launch>
  <arg name="model" default="$(find roboracer_gazebo)/urdf/unicorn.urdf"/>
  <arg name="world" default="worlds/empty.world"/>
  <arg name="gui" default="true"/>
  <arg name="use_sim_time" default="true"/>

  <param name="use_sim_time" value="$(arg use_sim_time)"/>

  <!-- Gazebo (shared, one instance) -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world)"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="$(arg use_sim_time)"/>
  </include>

  <!-- ==================== Unicorn 1 ==================== -->
  <group ns="unicorn1">
    <param name="robot_description" command="$(find xacro)/xacro $(arg model)"/>

    <node name="spawn_urdf" pkg="gazebo_ros" type="spawn_model"
          args="-param robot_description -urdf -model unicorn1 -x 0 -y 0 -z 0.05"
          output="screen"/>

    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher">
      <param name="publish_frequency" value="30.0"/>
    </node>

    <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher"/>

    <rosparam file="$(find roboracer_gazebo)/config/unicorn_control.yaml" command="load" ns="control"/>
  </group>

  <!-- ==================== Unicorn 2 ==================== -->
  <group ns="unicorn2">
    <param name="robot_description" command="$(find xacro)/xacro $(arg model)"/>

    <node name="spawn_urdf" pkg="gazebo_ros" type="spawn_model"
          args="-param robot_description -urdf -model unicorn2 -x 0 -y 1.0 -z 0.05"
          output="screen"/>

    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher">
      <param name="publish_frequency" value="30.0"/>
    </node>

    <node name="joint_state_publisher" pkg="joint_state_publisher" type="joint_state_publisher"/>

    <rosparam file="$(find roboracer_gazebo)/config/unicorn_control.yaml" command="load" ns="control"/>
  </group>
</launch>
